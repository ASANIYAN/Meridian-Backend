# Application
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
WS_PORT=3001

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=meridian_db
DATABASE_USER=meridian_user
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_URL=postgresql://meridian_user:password@localhost:5432/meridian_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
PASSWORD_RESET_MAX_ATTEMPTS=3

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=noreply@meridian.so
EMAIL_FROM_NAME=Meridian
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Share Links
SHARE_LINK_EXPIRY_DAYS=7

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000
AI_MAX_RETRIES=2
AI_REQUESTS_PER_MINUTE=10
AI_DAILY_CAP_PER_DOCUMENT=100

# BullMQ / Outbox
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BASE_DELAY_MS=1000
OUTBOX_MAX_DELAY_MS=30000
SNAPSHOT_OPERATION_THRESHOLD=1000
SNAPSHOT_INTERVAL_MINUTES=30

# Rate Limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
AUTH_THROTTLE_TTL_MS=900000
AUTH_THROTTLE_LIMIT=5
WS_MESSAGE_RATE_LIMIT=50
WS_CONNECTION_RATE_LIMIT=10