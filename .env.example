# Application
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
POSTGRES_PASSWORD=your_postgres_password
DB_URL=postgresql://meridian:your_postgres_password@localhost:5432/meridian

# Redis
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379

# JWT
JWT_SECRET=your_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
PASSWORD_RESET_MAX_ATTEMPTS=3

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Share Links
SHARE_LINK_EXPIRY_DAYS=7

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_MAX_TOKENS=1000
AI_MAX_RETRIES=2
AI_REQUESTS_PER_MINUTE=10
AI_DAILY_CAP_PER_DOCUMENT=100

# BullMQ / Outbox
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BASE_DELAY_MS=1000
OUTBOX_MAX_DELAY_MS=30000
SNAPSHOT_OPERATION_THRESHOLD=1000
SNAPSHOT_INTERVAL_MINUTES=30

# Rate Limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
AUTH_THROTTLE_TTL_MS=900000
AUTH_THROTTLE_LIMIT=5
WS_MESSAGE_RATE_LIMIT=50
WS_CONNECTION_RATE_LIMIT=10
