# Application
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
WS_PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meridian_db
DB_USER=meridian_user
DB_PASSWORD=your_db_password
DB_SSL=false
DB_URL=postgresql://your_db_user_name:your_db_password@localhost:5432/your_db_name

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_TLS=false

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@meridian.local
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password

# JWT
JWT_SECRET=your_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
PASSWORD_RESET_MAX_ATTEMPTS=3

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=noreply@meridian.so
EMAIL_FROM_NAME=Meridian
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Share Links
SHARE_LINK_EXPIRY_DAYS=7

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000
AI_MAX_RETRIES=2
AI_REQUESTS_PER_MINUTE=10
AI_DAILY_CAP_PER_DOCUMENT=100

# BullMQ / Outbox
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BASE_DELAY_MS=1000
OUTBOX_MAX_DELAY_MS=30000
SNAPSHOT_OPERATION_THRESHOLD=1000
SNAPSHOT_INTERVAL_MINUTES=30

# Rate Limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
AUTH_THROTTLE_TTL_MS=900000
AUTH_THROTTLE_LIMIT=5
WS_MESSAGE_RATE_LIMIT=50
WS_CONNECTION_RATE_LIMIT=10
